name: Run Chatbot Tests

on:
  push:
    branches: [ "main" ]  # 코드가 main 브랜치에 push될 때마다 실행
  pull_request:
    branches: [ "main" ]

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
    - name: 체크아웃 소스코드
      uses: actions/checkout@v4

    - name: 파이썬 환경 설정
      uses: actions/setup-python@v5
      with:
        python-version: '3.10' # 프로젝트 버전에 맞게 수정 가능

    - name: 의존성 패키지 설치
      run: |
        python -m pip install --upgrade pip
        if [ -f requirements.txt ]; then pip install -r requirements.txt; fi

    - name: 테스트 실행 (환경변수 주입)
      env:
        # 이 부분이 중요합니다! 저장소 금고에 넣은 실제 키를 가상환경에 주입합니다.
        OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
        ADMIN_API_KEY: ${{ secrets.ADMIN_API_KEY }}
      run: |
        # 클로드가 짜준 테스트 실행 명령어를 적습니다. (예: pytest 등)
        # 만약 별도의 테스트 파일이 없다면 우선 파일이 잘 실행되는지 아래처럼 검증할 수 있습니다.
        python -m unittest discover -s . -p "*test*.py"
